<view class="container">
  <!-- 顶部横幅 -->
  <view class="banner">
    <text class="banner-title">🌸 花伴</text>
    <text class="banner-subtitle">让每一朵花找到它的主人</text>
  </view>

  <!-- 推荐商品列表 -->
  <view class="section" wx:for="{{sections}}" wx:key="title">
    <text class="section-title">{{item.title}}</text>
    <scroll-view scroll-x class="product-scroll">
      <view class="product-card" wx:for="{{item.products}}" wx:key="_id"
            bindtap="goProduct" data-id="{{item._id}}">
        <image class="product-img" src="{{item.imageUrl}}" mode="aspectFill" />
        <text class="product-name">{{item.name}}</text>
        <view class="price-row">
          <text class="price">¥{{item.price}}</text>
          <text class="distance" wx:if="{{item.distance}}">{{item.distance}}km</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 种花入口 -->
  <view class="garden-banner" bindtap="goGarden">
    <text class="garden-emoji">🌻</text>
    <view class="garden-text">
      <text class="garden-title">每日种花</text>
      <text class="garden-desc">种满100天免费送花到家</text>
    </view>
    <text class="garden-arrow">→</text>
  </view>
</view>
