/* pages/map/map.wxss */
.container { height: 100vh; display: flex; flex-direction: column; }
.map-container { flex: 1; width: 100%; }
map { width: 100%; height: 100%; }
.bottom-panel { background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 24rpx; max-height: 40vh; overflow-y: auto; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1); }
.panel-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 12rpx; }
.supplier-card { display: flex; padding: 16rpx; border-bottom: 1rpx solid #f0f0f0; }
.supplier-info { flex: 1; margin-left: 12rpx; }
.supplier-name { font-size: 28rpx; font-weight: bold; color: #333; }
.supplier-addr { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.supplier-count { font-size: 22rpx; color: #4CAF50; margin-top: 4rpx; }
