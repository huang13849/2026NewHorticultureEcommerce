/* pages/garden/garden.wxss */
.container { padding: 16rpx; background: #f5f5f5; min-height: 100vh; }
.section { margin-bottom: 24rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 12rpx; }
.section-desc { font-size: 24rpx; color: #795548; margin-bottom: 16rpx; }
.empty-garden { background: #fff; border-radius: 16rpx; padding: 48rpx; text-align: center; margin-top: 12rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.empty-sub { font-size: 24rpx; color: #ccc; margin-top: 8rpx; }
.plot-card { background: #fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.plot-card.mature { border: 2rpx solid #FFD700; }
.plot-header { display: flex; align-items: center; }
.plot-emoji { font-size: 64rpx; }
.plot-info { margin-left: 16rpx; flex: 1; }
.plot-name { font-size: 30rpx; font-weight: bold; color: #333; }
.plot-status { font-size: 24rpx; color: #795548; margin-top: 4rpx; }
.progress-bar { height: 12rpx; background: #E8F5E9; border-radius: 6rpx; margin-top: 16rpx; overflow: hidden; }
.progress-fill { height: 100%; background: #4CAF50; border-radius: 6rpx; transition: width 0.3s; }
.progress-text { font-size: 20rpx; color: #999; text-align: right; margin-top: 4rpx; }
.plot-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.water-btn { background: #2196F3; color: #fff; border-radius: 32rpx; padding: 12rpx 24rpx; font-size: 24rpx; border: none; }
.sun-btn { background: #FFF8E1; border-radius: 32rpx; padding: 12rpx 20rpx; font-size: 24rpx; border: none; }
.claim-btn { background: #FF9800; color: #fff; border-radius: 32rpx; padding: 12rpx 24rpx; font-size: 24rpx; border: none; flex: 1; text-align: center; }
.checkin-text { font-size: 22rpx; color: #999; margin-top: 12rpx; }
.plant-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.plant-card { width: 48%; background: #fff; border-radius: 16rpx; padding: 20rpx; text-align: center; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.plant-emoji { font-size: 72rpx; }
.plant-name { font-size: 28rpx; font-weight: bold; color: #333; margin-top: 8rpx; }
.plant-days { font-size: 22rpx; color: #795548; margin-top: 4rpx; }
